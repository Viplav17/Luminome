# MutationMap — environment variables template
# Copy this file to .env and fill in your values
# .env is git-ignored; this file is committed as documentation

# Google Gemini — SERVER-SIDE ONLY. Never expose in frontend.
GEMINI_API_KEY=

# OMIM phenotype data — apply for a key at omim.org/api
OMIM_API_KEY=

# NCBI / ClinVar — free but a key raises rate limit from 3 to 10 requests/sec
# Register at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/mutationmap

# Redis
REDIS_URL=redis://localhost:6379

# Backend server port
PORT=3001

# Override in .env to point frontend at a deployed backend
BACKEND_BASE=http://localhost:3001